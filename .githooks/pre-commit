#!/bin/sh
# Reminder hook: keep the vendored `.claude/skills/*/_shared/` copies in sync
# with their canonical sources (the shared connector + templates).
#
# Non-blocking by design — it warns but never aborts the commit. Enable it with:
#     git config core.hooksPath .githooks
#
if command -v python3 >/dev/null 2>&1; then
    if ! python3 scripts/sync_shared.py --check; then
        echo ""
        echo "  ^ reminder: you changed a canonical shared file but the vendored"
        echo "    _shared/ copies are stale. Run:  python3 scripts/sync_shared.py"
        echo "    then re-stage the _shared files. (commit NOT blocked)"
        echo ""
    fi
fi
exit 0
