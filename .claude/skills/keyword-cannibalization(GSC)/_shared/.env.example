# ============================================================================
#  Onsite Checking Workflow — secrets template
#  Copy to .env (gitignored) and fill in. Do NOT put real values here.
# ============================================================================

# --- Google Search Console (OAuth installed-app) --------------------------
# One "Desktop app" OAuth client (Google Cloud Console -> APIs & Services ->
# Credentials) works for ALL agency Google accounts. Set the consent screen to
# "Production" so refresh tokens don't expire after 7 days ("Testing" mode).
GSC_OAUTH_CLIENT_ID=
GSC_OAUTH_CLIENT_SECRET=
# Alternative to the two values above — path to the downloaded client JSON:
# GSC_OAUTH_CLIENT_SECRET_FILE=gsc/credentials/client_secret.json

# Where per-account refresh tokens are cached (one token_<account>.json each).
GSC_TOKEN_DIR=gsc/credentials

# Optional default account slug used when --account is omitted.
GSC_DEFAULT_ACCOUNT=
